{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "summary_short",
    "summary_full",
    "memory_candidates",
    "drop_candidates",
    "risk_flags",
    "needs_premium_review"
  ],
  "properties": {
    "summary_short": { "type": "string" },
    "summary_full": { "type": "string" },
    "memory_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "confidence", "why"],
        "properties": {
          "text": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "why": { "type": "string" }
        }
      }
    },
    "drop_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "why"],
        "properties": {
          "text": { "type": "string" },
          "why": { "type": "string" }
        }
      }
    },
    "risk_flags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "needs_premium_review": { "type": "boolean" }
  }
}
